# ============================================================
# Company Document Finder v2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ============================================================

# ── Valkey (BSD-licensed Redis fork) ──────────────────────────
VALKEY_URL=valkey://valkey:6379/0

# ── MongoDB ────────────────────────────────────────────────────
MONGODB_URL=mongodb://admin:docufinderpassword@mongodb:27017
MONGODB_DB_NAME=company_docs
MONGO_USERNAME=admin
MONGO_PASSWORD=docufinderpassword

# ── Qdrant (Cloud-hosted) ──────────────────────────────────────
# Full URL for cloud Qdrant — overrides QDRANT_HOST/PORT
QDRANT_URL=https://your-cluster.us-west-2-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here
# For local Qdrant, set QDRANT_URL= (empty) and use host/port:
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333
COLLECTION_NAME=company_docs

# ── Ollama (local LLM — Gemma 4) ──────────────────────────────
# For Docker containers reaching host Ollama, use host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b
# Ollama API key (if required by your setup)
OLLAMA_API_KEY=

# ── Embedding ──────────────────────────────────────────────────
EMBED_MODEL_NAME=BAAI/bge-large-en-v1.5
EMBED_PROVIDER=local                   # local | gpu_worker
EMBED_WORKER_URL=http://embed-worker:50051
EMBED_BATCH_SIZE=256

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256

# ── Parsing (self-hosted default) ─────────────────────────────
PARSER_PROVIDER=unstructured           # unstructured | liteparse | llamaparse
UNSTRUCTURED_URL=http://unstructured-lb:8000
UNSTRUCTURED_STRATEGY=fast             # fast | hi_res

# ── Parsing — PDF classification & router ─────────────────────
ENABLE_PDF_CLASSIFICATION=true
UNSTRUCTURED_SCALE=4

# ── Per-type parser overrides (optional — override ROUTING_TABLE) ──
# PARSER_TEXT_DENSE=liteparse
# PARSER_SCANNED=unstructured
# PARSER_COMPLEX=llamaparse
# PARSER_MIXED=unstructured
# PARSER_DOCX=unstructured

# ── LlamaCloud (optional — required for llamaparse/llamaextract/etc) ──
LLAMA_CLOUD_API_KEY=
LLAMAPARSE_TIER=cost_effective         # fast | cost_effective | agentic | agentic_plus

# ── Chunking ───────────────────────────────────────────────────
CHUNKING_STRATEGY=recursive            # recursive | sentence | semantic
# ⚠️ semantic requires 2x memory (embed model loaded during chunking)

# ── LLM provider ───────────────────────────────────────────────
LLM_PROVIDER=ollama                    # ollama | llamacloud

# ── Index provider ─────────────────────────────────────────────
INDEX_PROVIDER=local_qdrant            # local_qdrant | llamacloud

# ── Extra providers ────────────────────────────────────────────
EXTRACT_PROVIDER=local                 # local | llamaextract
SPLIT_PROVIDER=local                   # local | llamasplit
CLASSIFY_PROVIDER=local                # local | llamaclassify
AGENT_PROVIDER=local                   # local | llamaagents
SHEETS_PROVIDER=local                  # local | llamasheets

# ── File paths ─────────────────────────────────────────────────
WATCH_ROOT=/app/watch_root
UPLOAD_DIR=/app/uploads

# ── Environment ────────────────────────────────────────────────
ENVIRONMENT=development
GIT_SHA=local

# ── Rate limiting ──────────────────────────────────────────────
UPLOAD_MB_LIMIT_PER_MINUTE=100

# ── Virus scanning (ClamAV) ────────────────────────────────────
ENABLE_VIRUS_SCAN=false                # true for high-security (adds ~200ms latency)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ── Backup — S3/MinIO ──────────────────────────────────────────
BACKUP_DESTINATION=s3                  # local | s3
BACKUP_S3_BUCKET=company-docs-backup
BACKUP_S3_ENDPOINT=http://minio:9000   # Omit for AWS S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
BACKUP_RETENTION_DAYS=30

# ── MinIO (self-hosted S3 alternative) ────────────────────────
# API:    http://127.0.0.1:9000
# WebUI:  http://127.0.0.1:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── Observability ──────────────────────────────────────────────
PHOENIX_ENDPOINT=http://phoenix:4317   # OTLP gRPC endpoint
